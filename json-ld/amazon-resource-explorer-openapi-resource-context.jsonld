{
  "@context": {
    "@version": 1.1,
    "aws": "https://aws.amazon.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Resource": "aws:Resource",
    "Arn": {
      "@id": "aws:Arn",
      "@type": "xsd:string"
    },
    "LastReportedAt": {
      "@id": "aws:LastReportedAt",
      "@type": "xsd:dateTime"
    },
    "OwningAccountId": {
      "@id": "aws:OwningAccountId",
      "@type": "xsd:string"
    },
    "Region": {
      "@id": "aws:Region",
      "@type": "xsd:string"
    },
    "ResourceType": {
      "@id": "aws:ResourceType",
      "@type": "xsd:string"
    },
    "Service": {
      "@id": "aws:Service",
      "@type": "xsd:string"
    }
  }
}