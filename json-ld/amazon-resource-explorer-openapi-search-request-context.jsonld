{
  "@context": {
    "@version": 1.1,
    "aws": "https://aws.amazon.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "SearchRequest": "aws:SearchRequest",
    "QueryString": {
      "@id": "aws:QueryString",
      "@type": "xsd:string"
    },
    "MaxResults": {
      "@id": "aws:MaxResults",
      "@type": "xsd:integer"
    },
    "NextToken": {
      "@id": "aws:NextToken",
      "@type": "xsd:string"
    },
    "ViewArn": {
      "@id": "aws:ViewArn",
      "@type": "xsd:string"
    }
  }
}